# --- Extension / marketing ---
PUBLIC_CHROME_URL=https://chromewebstore.google.com/detail/your-extension-id

# --- Creem (Billing) — static hosted checkout links ---
# One product per plan+period. Copy each product's "Share" checkout URL from the
# Creem dashboard (Products → your product → Share / checkout link).
PUBLIC_CREEM_CHECKOUT_HOBBY_M=https://creem.io/payment/prod_hobby_monthly
PUBLIC_CREEM_CHECKOUT_HOBBY_Y=https://creem.io/payment/prod_hobby_yearly
PUBLIC_CREEM_CHECKOUT_EXPERT_M=https://creem.io/payment/prod_expert_monthly
PUBLIC_CREEM_CHECKOUT_EXPERT_Y=https://creem.io/payment/prod_expert_yearly
# Customer self-service portal link (Creem dashboard → Customer portal).
PUBLIC_CREEM_PORTAL_URL=https://creem.io/my-orders

# --- Supabase (admin panel reads these; anon key is public) ---
PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
PUBLIC_SUPABASE_ANON_KEY=your_anon_key

# ---------------------------------------------------------------------------
# SERVER-SIDE SECRETS — do NOT put these in the static build / GitHub Actions
# public vars. Set them with `supabase secrets set ...` for the Edge Functions.
# ---------------------------------------------------------------------------
# CREEM_API_KEY=creem_live_or_test_xxx        # license-verify → validate keys
# CREEM_WEBHOOK_SECRET=whsec_xxx              # creem-webhook signature check
# CREEM_PRODUCT_HOBBY_M=prod_xxx              # product-id → plan mapping
# CREEM_PRODUCT_HOBBY_Y=prod_xxx
# CREEM_PRODUCT_EXPERT_M=prod_xxx
# CREEM_PRODUCT_EXPERT_Y=prod_xxx
