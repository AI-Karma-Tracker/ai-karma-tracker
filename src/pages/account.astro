---
import Base from '../layouts/Base.astro';
// Creem customer portal URL. Set PUBLIC_CREEM_PORTAL_URL to your account's
// customer-portal link so subscribers can manage / cancel their plan.
const portal = import.meta.env.PUBLIC_CREEM_PORTAL_URL ?? '';
const hasPortal = portal && portal !== '#';
---
<Base title="Manage your plan — AI Karma Tracker">
  <main class="wrap" style="max-width:520px; padding-top:64px; padding-bottom:40px">
    <div class="panel">
      <h2 style="margin:0">Manage your plan</h2>
      <p class="muted" style="margin-top:8px">Your subscription is handled securely by Creem. Change plan, update payment or cancel anytime.</p>

      {hasPortal ? (
        <a class="btn" style="margin-top:18px" href={portal} target="_blank" rel="noopener">Open billing portal →</a>
      ) : (
        <div class="alert ok" style="margin-top:18px; background:#f6f7fb; border-color:var(--border); color:var(--fg)">
          To manage or cancel your subscription, use the <b>“Manage subscription”</b> link in your Creem receipt email.
        </div>
      )}

      <hr style="border:0;border-top:1px solid var(--border);margin:24px 0" />

      <h3 style="margin:0 0 6px;font-size:16px">Activate Pro in the extension</h3>
      <ol class="muted" style="margin:0;padding-left:20px;font-size:14.5px;line-height:1.9">
        <li>Open the extension → <b>Settings</b>.</li>
        <li>Paste the license key from your Creem receipt email.</li>
        <li>Click <b>Verify license</b> — Pro unlocks instantly.</li>
      </ol>
    </div>
    <p class="muted" style="text-align:center;margin-top:16px;font-size:13px">
      Are you the site owner? <a href="/admin" style="color:var(--brand)">Admin panel →</a>
    </p>
  </main>
</Base>
