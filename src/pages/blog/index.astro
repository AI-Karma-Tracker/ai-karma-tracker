---
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';
const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf(),
);
const fmt = (d) => d.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
---
<Base title="Blog & Tips — AI Karma Tracker" description="Tips and guides for getting the most out of your AI usage limits.">
  <header class="wrap" style="padding:64px 24px 0; text-align:center">
    <p style="font-size:13px; font-weight:700; letter-spacing:.08em; color:var(--brand-ink)">BLOG &amp; TIPS</p>
    <h1 style="font-size:42px; margin-top:10px">Make your AI limits go further</h1>
    <p class="muted" style="font-size:18px; max-width:560px; margin:16px auto 0">Short, practical guides on limits, resets and peak hours across the major AI tools.</p>
  </header>

  <section class="wrap" style="padding:44px 24px 0">
    <div style="display:grid; grid-template-columns:repeat(auto-fit,minmax(300px,1fr)); gap:16px">
      {posts.map((p) => (
        <a class="card reveal" href={`/blog/${p.id}`} style="padding:22px; display:block; transition:box-shadow .2s ease">
          <div style="display:flex; gap:8px; align-items:center; font-size:12px">
            <span style="font-weight:700; color:var(--brand-ink); background:#eef2ff; border:1px solid #e0e7ff; padding:2px 8px; border-radius:999px">{p.data.tag}</span>
            <span class="muted">{fmt(p.data.date)} · {p.data.readMins} min</span>
          </div>
          <h2 style="font-size:20px; margin-top:12px">{p.data.title}</h2>
          <p class="muted" style="margin-top:8px; font-size:15px">{p.data.description}</p>
          <span style="display:inline-block; margin-top:12px; color:var(--brand); font-weight:600; font-size:14px">Read →</span>
        </a>
      ))}
    </div>
  </section>
</Base>
